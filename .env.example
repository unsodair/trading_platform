# ===== Trading Platform Configuration =====

# Mode: paper | live
TRADING_MODE=paper

# ===== Dhan Broker =====
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# ===== LLM Configuration =====
# Active LLM: openai | anthropic | gemini | ollama
ACTIVE_LLM=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ===== Risk Controls =====
MAX_LOSS_PER_DAY=5000
MAX_ORDER_SIZE=100000
MAX_OPEN_POSITIONS=10
ALLOWED_TRADING_START=09:15
ALLOWED_TRADING_END=15:30
COOLDOWN_BETWEEN_TRADES_SECONDS=30
MANDATORY_STOP_LOSS_PERCENT=2.0

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./trading_platform.db

# ===== GitHub Discovery =====
GITHUB_TOKEN=ghp_your_github_token

# ===== App Settings =====
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production
